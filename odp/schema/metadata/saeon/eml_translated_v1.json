{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "value": { "type": "string" },
          "lang": { "type": "string" }
        },
        "required": ["value"],
        "translations": [
          {
            "t9nScheme": "saeon/datacite4",
            "t9nTarget": "/titles",
            "t9nArray": {
              "t9nObject": {
                "title": { "t9nSource": "0/value" },
                "lang": { "t9nSource": "0/lang" }
              }
            }
          }
        ]
      },
      "minItems": 1
    },

    "pubDate": {
      "type": "string",
      "format": "date",
      "description": "Publication date in ISO 8601 format (e.g., YYYY or YYYY-MM-DD)",
      "translations": [
        {
          "t9nScheme": "saeon/datacite4",
          "t9nTarget": "/publicationYear",
          "t9nFilter": "date-to-year"
        },
        {
          "t9nScheme": "saeon/datacite4",
          "t9nTarget": "/dates",
          "t9nArray": {
            "t9nObject": {
              "date": { "t9nSource": "0" },
              "dateType": { "t9nConst": "Issued" }
            }
          }
        }
      ]
    },

    "responsibleParty": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "individualName": {
            "type": "string",
            "description": "The full name of the responsible or associated party."
          },
          "organizationName": {
            "type": "string",
            "description": "The full name of the organization that is associated with the resource."
          },
          "positionName": {
            "type": "string",
            "description": "Used when the role changes frequently; e.g., GBIF Data Manager."
          },
          "role": {
            "type": "string",
            "description": "Function performed by the responsible party."
          },
          "personnel": {
            "type": "string",
            "description": "Documents people involved in a research project with contact info and role."
          },
          "contact": {
            "type": "object",
            "description": "Information required to enable contact with the responsible person or organization.",
            "properties": {
              "phone": { "type": "string", "description": "Telephone or fax number." },
              "address": {
                "type": "object",
                "properties": {
                  "deliveryPoint": { "type": "string" },
                  "city": { "type": "string" },
                  "administrativeArea": { "type": "string" },
                  "postalCode": { "type": "string" },
                  "country": { "type": "string" },
                  "electronicMailAddress": {
                    "type": "array",
                    "items": { "type": "string", "format": "email" }
                  }
                }
              },
              "onlineUrl": { "type": "string", "format": "uri" }
            },
            "required": []
          }
        },
        "required": ["role"],
        "anyOf": [
          { "required": ["individualName"] },
          { "required": ["organizationName"] },
          { "required": ["positionName"] }
        ],
        "translations": [
          {
            "t9nScheme": "saeon/datacite4",
            "t9nTarget": "/publisher",
            "t9nCondition": {
              "properties": {
                "role": { "const": "publisher" }
              }
            },
            "t9nSource": "0/organizationName"
          },
          {
            "t9nScheme": "saeon/datacite4",
            "t9nTarget": "/creators",
            "t9nCondition": {
              "properties": { "role": { "enum": ["originator", "principalInvestigator", "creator"] } }
            },
            "t9nArray": {
              "t9nObject": {
                "name": { "t9nSource": "0/individualName" },
                "nameIdentifiers": {
                  "t9nArray": {
                    "t9nObject": {
                      "nameIdentifier": { "t9nSource": "0/contact/onlineUrl" },
                      "nameIdentifierScheme": { "t9nSource": "0/contact/onlineUrl", "t9nFilter": "base-url" },
                      "schemeURI": { "t9nSource": "0/contact/onlineUrl", "t9nFilter": "base-url" }
                    }
                  }
                },
                "affiliation": {
                  "t9nArray": {
                    "t9nObject": {
                      "affiliation": {
                        "t9nConcat": [
                          "0/organizationName",
                          "0/positionName",
                          "0/contact/address/deliveryPoint",
                          "0/contact/electronicMailAddress/0"
                        ],
                        "t9nSep": "\n"
                      }
                    }
                  }
                }
              }
            }
          },
          {
            "t9nScheme": "saeon/datacite4",
            "t9nTarget": "/contributors",
            "t9nCondition": {
              "properties": {
                "role": {
                  "enum": ["resourceProvider", "custodian", "owner", "distributor", "pointOfContact", "processor", "contact"]
                }
              }
            },
            "t9nArray": {
              "t9nObject": {
                "name": { "t9nSource": "0/individualName" },
                "nameIdentifiers": {
                  "t9nArray": {
                    "t9nObject": {
                      "nameIdentifier": { "t9nSource": "0/contact/onlineUrl" },
                      "nameIdentifierScheme": { "t9nSource": "0/contact/onlineUrl", "t9nFilter": "base-url" }
                    }
                  }
                },
                "affiliation": {
                  "t9nArray": {
                    "t9nObject": {
                      "affiliation": { "t9nSource": "0/organizationName" }
                    }
                  }
                },
                "contributorType": {
                  "t9nSource": "0/role",
                  "t9nFilter": {
                    "resourceProvider": "HostingInstitution",
                    "custodian": "DataManager",
                    "owner": "RightsHolder",
                    "distributor": "Distributor",
                    "pointOfContact": "ContactPerson",
                    "processor": "ProjectMember",
                    "contact": "ContactPerson"
                  }
                }
              }
            }
          }
        ]
      },
      "minItems": 1
    },

    "geographicCoverage": {
      "type": "object",
      "properties": {
        "boundingCoordinates": {
          "type": "object",
          "description": "Bounding Coordinates are the four margins (N, S, E, W) of a bounding box, or when considered in lat-lon pairs, the corners of the box.",
          "properties": {
            "northBoundingCoordinate": { "type": "number" },
            "southBoundingCoordinate": { "type": "number" },
            "eastBoundingCoordinate": { "type": "number" },
            "westBoundingCoordinate": { "type": "number" },
            "boundingAltitudes": {
              "type": "object",
              "properties": {
                "altitudeMaximum": { "type": "number" },
                "altitudeMinimum": { "type": "number" },
                "altitudeUnits": {
                  "type": "string",
                  "enum": [
                    "meter", "nanometer", "micrometer", "micron",
                    "millimeter", "centimeter", "decimeter",
                    "decameter", "hectometer", "kilometer"
                  ]
                }
              },
              "required": []
            }
          },
          "required": [
            "northBoundingCoordinate",
            "southBoundingCoordinate",
            "eastBoundingCoordinate",
            "westBoundingCoordinate"
          ],
          "translations": [
            {
              "t9nScheme": "saeon/datacite4",
              "t9nTarget": "/geoLocations",
              "t9nArray": {
                "t9nObject": {
                  "geoLocationBox": {
                    "t9nConcat": [
                      "0/westBoundingCoordinate",
                      "0/southBoundingCoordinate",
                      "0/eastBoundingCoordinate",
                      "0/northBoundingCoordinate"
                    ],
                    "t9nSep": " "
                  }
                }
              }
            }
          ]
        }
      },
      "required": ["boundingCoordinates"]
    },

    "language": {
      "type": "string",
      "description": "ISO 639-1 two-letter code",
      "translations": [
        {
          "t9nScheme": "saeon/datacite4",
          "t9nTarget": "/language",
          "t9nSource": "0"
        }
      ]
    },

    "characterEncoding": {
      "type": "string",
      "translations": [
        {
          "t9nScheme": "saeon/datacite4",
          "t9nTarget": "/additionalFields/characterEncoding",
          "t9nSource": "0"
        }
      ]
    },

    "descriptor": {
      "type": "string",
      "translations": [
        {
          "t9nScheme": "saeon/datacite4",
          "t9nTarget": "/additionalFields/
