    "onlineResources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/onlineResource",
        "required": [
          "description"
        ],
        "translations": [
          {
            "$comment": "case 1: single file type download",
            "t9nScheme": "saeon/datacite4",
            "t9nTarget": "/immutableResource",
            "t9nCondition": {
              "properties": {
                "description": {
                  "const": "download"
                },
                "applicationProfile": {
                  "pattern": "^\\w+$"
                }
              }
            },
            "t9nObject": {
              "resourceName": {
                "t9nSource": "0/name"
              },
              "resourceDownload": {
                "t9nObject": {
                  "downloadURL": {
                    "t9nSource": "0/linkage"
                  },
                  "fileFormat": {
                    "t9nSource": "0/applicationProfile"
                  }
                }
              }
            }
          },
          {
            "$comment": "case 2: archive download",
            "t9nScheme": "saeon/datacite4",
            "t9nTarget": "/immutableResource",
            "t9nCondition": {
              "properties": {
                "description": {
                  "const": "download"
                },
                "applicationProfile": {
                  "pattern": "^\\[\\s*\\w+\\s*(,\\s*\\w+\\s*)*]$"
                }
              },
              "required": [
                "applicationProfile"
              ]
            },
            "t9nObject": {
              "resourceName": {
                "t9nSource": "0/name"
              },
              "resourceDownload": {
                "t9nObject": {
                  "downloadURL": {
                    "t9nSource": "0/linkage"
                  },
                  "archive": {
                    "t9nConst": true
                  },
                  "archivedFormats": {
                    "t9nSource": "0/applicationProfile",
                    "t9nFilter": "split-archived-formats"
                  }
                }
              }
            }
          },
          {
            "$comment": "case 3: query link",
            "t9nScheme": "saeon/datacite4",
            "t9nTarget": "/linkedResources",
            "t9nCondition": {
              "properties": {
                "description": {
                  "const": "search"
                },
                "applicationProfile": {
                  "enum": [
                    "GeoServer",
                    "Esri",
                    "THREDDS"
                  ]
                }
              }
            },
            "t9nArray": {
              "t9nObject": {
                "resourceURL": {
                  "t9nSource": "0/linkage"
                },
                "resourceName": {
                  "t9nSource": "0/name"
                },
                "linkedResourceType": {
                  "t9nConst": "Query"
                },
                "serverType": {
                  "t9nSource": "0/applicationProfile"
                }
              }
            }
          },
          {
            "$comment": "case 4: other linked resources",
            "t9nScheme": "saeon/datacite4",
            "t9nTarget": "/linkedResources",
            "t9nCondition": {
              "properties": {
                "description": {
                  "enum": [
                    "information",
                    "offlineAccess",
                    "order"
                  ]
                }
              }
            },
            "t9nArray": {
              "t9nObject": {
                "resourceURL": {
                  "t9nSource": "0/linkage"
                },
                "resourceName": {
                  "t9nSource": "0/name"
                },
                "linkedResourceType": {
                  "t9nSource": "0/description",
                  "t9nFilter": {
                    "information": "Information",
                    "offlineAccess": "OfflineAccess",
                    "order": "ConditionalAccess"
                  }
                }
              }
            }
          }
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
