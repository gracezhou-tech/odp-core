{
  "$schema": "https://jschon.dev/meta/translation/schema",
  "$id": "https://odp.saeon.ac.za/schema/metadata/saeon/eml",
  "type": "object",
  "translations": [
    {
      "t9nScheme": "saeon/datacite4",
      "t9nTarget": "/",
      "t9nConst": {
        "schemaVersion": "https://schema.datacite.org/meta/kernel-4.3/metadata.xsd"
      }
    },
    {
      "t9nScheme": "saeon/datacite4",
      "t9nTarget": "/types",
      "t9nConst": {
        "resourceTypeGeneral": "Dataset",
        "resourceType": "Data"
      }
    },
    {
      "t9nScheme": "saeon/datacite4",
      "t9nTarget": "/publisher",
      "t9nConst": "SAEON"
    }
  ],
  "properties": {
    "doi": {
      "type": "string",
      "pattern": "^10\\.\\d{4,}(\\.\\d+)*/[-._;()/:a-zA-Z0-9]+$",
      "translations": [
        {
          "t9nScheme": "saeon/datacite4",
          "t9nTarget": "/doi",
          "t9nObject": {
            "identifier": {
              "t9nSource": "0"
            },
            "identifierType": {
              "t9nConst": "DOI"
            }
          }
        }
      ]
    },
    "title": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "value": {
            "type": "string"
          },
          "lang": {
            "type": "string"
          }
        },
        "required": [
          "value"
        ]
      },
      "translations": [
        {
          "t9nScheme": "saeon/datacite4",
          "t9nTarget": "/titles",
          "t9nArray": {
            "t9nObject": {
              "title": {
                "t9nSource": "0/value"
              },
              "lang": {
                "t9nSource": "0/lang"
              }
            }
          }
        }
      ]
    },
    "pubDate": {
      "type": "string",
      "format": "date",
      "translations": [
        {
          "t9nScheme": "saeon/datacite4",
          "t9nTarget": "/publicationYear",
          "t9nSource": "0",
          "t9nFilter": "date-to-year"
        },
        {
          "t9nScheme": "saeon/datacite4",
          "t9nTarget": "/dates",
          "t9nArray": {
            "t9nObject": {
              "date": {
                "t9nSource": "0"
              },
              "dateType": {
                "t9nConst": "Issued"
              }
            }
          }
        }
      ]
    },
    "responsibleParty": {
      "type": "array",
      "minContains": 1,
      "description": "At least one party must have role author, principalInvestigator, or originator for DataCite Creator compliance.",
      "contains": {
        "type": "object",
        "properties": {
          "role": {
            "enum": [
              "author",
              "principalInvestigator",
              "originator"
            ]
          }
        },
        "required": [
          "role"
        ]
      },
      "items": {
        "type": "object",
        "properties": {
          "individualName": {
            "type": "object",
            "properties": {
              "givenName": {
                "type": "string"
              },
              "surName": {
                "type": "string"
              }
            },
            "required": [
              "surName"
            ]
          },
          "organizationName": {
            "type": "string"
          },
          "positionName": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        },
        "required": [
          "role"
        ],
        "anyOf": [
          {
            "required": [
              "individualName"
            ]
          },
          {
            "required": [
              "organizationName"
            ]
          },
          {
            "required": [
              "positionName"
            ]
          }
        ],
        "translations": [
          {
            "t9nScheme": "saeon/datacite4",
            "t9nTarget": "/creators",
            "t9nCondition": {
              "properties": {
                "role": {
                  "enum": [
                    "author",
                    "principalInvestigator",
                    "originator"
                  ]
                }
              }
            },
            "t9nArray": {
              "t9nObject": {
                "name": {
                  "t9nConcat": [
                    "0/individualName/surName",
                    "0/individualName/givenName"
                  ],
                  "t9nSep": ", "
                },
                "affiliation": {
                  "t9nArray": {
                    "t9nObject": {
                      "affiliation": {
                        "t9nSource": "0/organizationName"
                      }
                    }
                  }
                }
              }
            }
          },
          {
            "t9nScheme": "saeon/datacite4",
            "t9nTarget": "/contributors",
            "t9nCondition": {
              "properties": {
                "role": {
                  "enum": [
                    "metadataProvider",
                    "custodianSteward",
                    "owner",
                    "user",
                    "distributor",
                    "pointOfContact",
                    "processor",
                    "editor"
                  ]
                }
              }
            },
            "t9nArray": {
              "t9nObject": {
                "name": {
                  "t9nConcat": [
                    "0/individualName/surName",
                    "0/individualName/givenName"
                  ],
                  "t9nSep": ", "
                },
                "affiliation": {
                  "t9nArray": {
                    "t9nObject": {
                      "affiliation": {
                        "t9nSource": "0/organizationName"
                      }
                    }
                  }
                },
                "contributorType": {
                  "t9nSource": "0/role",
                  "t9nFilter": {
                    "metadataProvider": "HostingInstitution",
                    "custodianSteward": "DataManager",
                    "owner": "RightsHolder",
                    "user": "Other",
                    "distributor": "Distributor",
                    "pointOfContact": "ContactPerson",
                    "processor": "ProjectMember",
                    "editor": "Editor"
                  }
                }
              }
            }
          }
        ]
      }
    },
    "abstract": {
      "type": "string",
      "translations": [
        {
          "t9nScheme": "saeon/datacite4",
          "t9nTarget": "/descriptions",
          "t9nArray": {
            "t9nObject": {
              "description": {
                "t9nSource": "0"
              },
              "descriptionType": {
                "t9nConst": "Abstract"
              }
            }
          }
        }
      ]
    },
    "keywordSet": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "keyword": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "translations": [
        {
          "t9nScheme": "saeon/datacite4",
          "t9nTarget": "/subjects",
          "t9nArray": {
            "t9nObject": {
              "subject": {
                "t9nSource": "0"
              }
            }
          }
        }
      ]
    },
    "taxonomicCoverage": {
      "type": "object",
      "properties": {
        "generalTaxonomicCoverage": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "translations": [
            {
              "t9nScheme": "saeon/datacite4",
              "t9nTarget": "/subjects",
              "t9nArray": {
                "t9nObject": {
                  "subject": {
                    "t9nSource": "0"
                  },
                  "subjectScheme": {
                    "t9nConst": "SAEON Taxonomic Scope"
                  }
                }
              }
            }
          ]
        },
        "taxonomicClassification": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "taxonRankName": {
                "type": "string",
                "translations": [
                  {
                    "t9nScheme": "saeon/datacite4",
                    "t9nTarget": "/subjects",
                    "t9nArray": {
                      "t9nObject": {
                        "subject": {
                          "t9nSource": "0"
                        },
                        "subjectScheme": {
                          "t9nConst": "SAEON Taxonomic Scope"
                        }
                      }
                    }
                  }
                ]
              },
              "taxonRankValue": {
                "type": "string",
                "translations": [
                  {
                    "t9nScheme": "saeon/datacite4",
                    "t9nTarget": "/subjects",
                    "t9nArray": {
                      "t9nObject": {
                        "subject": {
                          "t9nSource": "0"
                        },
                        "subjectScheme": {
                          "t9nConst": "SAEON Taxonomic Scope"
                        }
                      }
                    }
                  }
                ]
              },
              "taxonId": {
                "type": "string",
                "translations": [
                  {
                    "t9nScheme": "saeon/datacite4",
                    "t9nTarget": "/relatedIdentifiers",
                    "t9nArray": {
                      "t9nObject": {
                        "relatedIdentifier": {
                          "t9nSource": "0"
                        },
                        "relationType": {
                          "t9nConst": "IsIdentifiedBy"
                        }
                      }
                    }
                  }
                ]
              },
              "commonName": {
                "type": "string",
                "translations": [
                  {
                    "t9nScheme": "saeon/datacite4",
                    "t9nTarget": "/subjects",
                    "t9nArray": {
                      "t9nObject": {
                        "subject": {
                          "t9nSource": "0"
                        },
                        "subjectScheme": {
                          "t9nConst": "SAEON Taxonomic Scope"
                        }
                      }
                    }
                  }
                ]
              }
            },
            "required": [
              "taxonRankName"
            ]
          }
        },
        "taxonomicSystem": {
          "type": "object",
          "properties": {
            "classificationSystem": {
              "type": "string"
            },
            "classificationSystemCitation": {
              "type": "string"
            },
            "classificationSystemModifications": {
              "type": "string"
            },
            "identificationReference": {
              "type": "string"
            },
            "identifierName": {
              "type": "string"
            },
            "taxonomicCompleteness": {
              "type": "string"
            },
            "taxonomicProcedures": {
              "type": "string"
            },
            "vouchers": {
              "type": "object",
              "properties": {
                "repository": {
                  "type": "object",
                  "properties": {
                    "originator": {
                      "type": "string"
                    }
                  }
                },
                "specimen": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "required": [
        "generalTaxonomicCoverage",
        "taxonomicClassification"
      ]
    }
  },
  "required": [
    "title",
    "pubDate",
    "responsibleParty",
    "abstract",
    "keywordSet",
    "intellectualRights",
    "geographicCoverage",
    "taxonomicCoverage"
  ]
}