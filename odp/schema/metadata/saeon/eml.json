                            "maximum": 180
                          },
                          "latitude": {
                            "type": "number",
                            "minimum": -90,
                            "maximum": 90
                          }
                        },
                        "additionalProperties": false
                      }
                    }
                  },
                  "additionalProperties": false
                }
              },
              "boundingCoordinates": {
                "type": "object",
                "required": [
                  "westBoundingCoordinate",
                  "eastBoundingCoordinate",
                  "southBoundingCoordinate",
                  "northBoundingCoordinate"
                ],
                "properties": {
                  "westBoundingCoordinate": {
                    "type": "number",
                    "minimum": -180,
                    "maximum": 180
                  },
                  "eastBoundingCoordinate": {
                    "type": "number",
                    "minimum": -180,
                    "maximum": 180
                  },
                  "southBoundingCoordinate": {
                    "type": "number",
                    "minimum": -90,
                    "maximum": 90
                  },
                  "northBoundingCoordinate": {
                    "type": "number",
                    "minimum": -90,
                    "maximum": 90
                  }
                },
                "additionalProperties": false
              },
              "geographicDescription": {
                "type": "string"
              },
              "boundingAltitudes": {
                "type": "object",
                "required": [
                  "altitudeMinimum",
                  "altitudeMaximum",
                  "altitudeUnits"
                ],
                "properties": {
                  "altitudeMinimum": {
                    "type": "number",
                    "translations": [
                      {
                        "t9nScheme": "saeon/datacite4",
                        "t9nTarget": "/subjects",
                        "t9nArray": {
                          "t9nObject": {
                            "subject": {
                              "t9nCast": "string"
                            },
                            "subjectScheme": {
                              "t9nConst": "EML altitudeMinimum"
                            }
                          }
                        }
                      }
                    ]
                  },
                  "altitudeMaximum": {
                    "type": "number",
                    "translations": [
                      {
                        "t9nScheme": "saeon/datacite4",
                        "t9nTarget": "/subjects",
                        "t9nArray": {
                          "t9nObject": {
                            "subject": {
                              "t9nCast": "string"
                            },
                            "subjectScheme": {
                              "t9nConst": "EML altitudeMaximum"
                            }
                          }
                        }
                      }
                    ]
                  },
                  "altitudeUnits": {
                    "type": "string",
                    "translations": [
                      {
                        "t9nScheme": "saeon/datacite4",
                        "t9nTarget": "/subjects",
                        "t9nArray": {
                          "t9nObject": {
                            "subject": {},
                            "subjectScheme": {
                              "t9nConst": "EML altitudeUnits"
                            }
                          }
                        }
                      }
                    ]
                  },
                  "altitudeDatumName": {
                    "type": "string",
                    "translations": [
                      {
                        "t9nScheme": "saeon/datacite4",
                        "t9nTarget": "/subjects",
                        "t9nArray": {
                          "t9nObject": {
                            "subject": {},
                            "subjectScheme": {
                              "t9nConst": "EML altitudeDatumName"
                            }
                          }
                        }
                      }
                    ]
                  }
                }
              }
            }
          },
          "translations": [
            {
              "t9nScheme": "saeon/datacite4",
              "t9nTarget": "/geoLocations",
              "t9nArray": {
                "t9nObject": {
                  "geoLocationPlace": {
                    "t9nSource": "0/geographicDescription"
                  },
                  "geoLocationBox": {
                    "t9nObject": {
                      "westBoundLongitude": {
                        "t9nSource": "0/boundingCoordinates/westBoundingCoordinate"
                      },
                      "eastBoundLongitude": {
                        "t9nSource": "0/boundingCoordinates/eastBoundingCoordinate"
                      },
                      "southBoundLatitude": {
                        "t9nSource": "0/boundingCoordinates/southBoundingCoordinate"
                      },
                      "northBoundLatitude": {
                        "t9nSource": "0/boundingCoordinates/northBoundingCoordinate"
                      }
                    }
                  },
                  "geoLocationPolygons": {
                    "t9nSource": "0/boundingPolygon",
                    "t9nArray": {
                      "t9nObject": {
                        "polygonPoints": {
                          "t9nSource": "0/polygon",
                          "t9nArray": {
                            "t9nObject": {
                              "pointLongitude": {
                                "t9nSource": "0/longitude"
                              },
                              "pointLatitude": {
                                "t9nSource": "0/latitude"
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          ]
        },
        "temporalCoverage": {
          "type": "object",
          "properties": {
            "rangeOfDates": {
              "type": "object",
              "properties": {
                "beginDate": {
                  "anyOf": [
                    {
                      "type": "string",
                      "format": "date-time"
                    },
                    {
                      "type": "string",
                      "format": "date"
                    }
                  ]
                },
                "endDate": {
                  "anyOf": [
                    {
                      "type": "string",
                      "format": "date-time"
                    },
                    {
                      "type": "string",
                      "format": "date"
                    }
                  ]
                }
              },
              "required": [
                "beginDate",
                "endDate"
              ],
              "additionalProperties": false
            },
            "singleDate": {
              "oneOf": [
                {
                  "type": "string",
                  "format": "date-time"
                },
                {
                  "type": "string",
                  "format": "date"
                }
              ]
            }
          },
          "anyOf": [
            {
              "required": [
                "rangeOfDates"
              ]
            },
            {
              "required": [
                "singleDate"
              ]
            }
          ],
          "additionalProperties": false,
          "translations": [
            {
              "t9nScheme": "saeon/datacite4",
              "t9nTarget": "/dates",
              "t9nCondition": {
                "required": [
                  "rangeOfDates"
                ]
              },
              "t9nArray": {
                "t9nObject": {
                  "date": {
                    "t9nConcat": [
                      "0/rangeOfDates/beginDate",
                      "0/rangeOfDates/endDate"
                    ],
                    "t9nSep": "/"
                  },
                  "dateType": {
                    "t9nConst": "Valid"
                  }
                }
              }
            },
            {
              "t9nScheme": "saeon/datacite4",
              "t9nTarget": "/dates",
              "t9nCondition": {
                "required": [
                  "singleDate"
                ]
              },
              "t9nArray": {
                "t9nObject": {
                  "date": {
                    "t9nSource": "0/singleDate"
                  },
                  "dateType": {
                    "t9nConst": "Collected"
                  }
                }
              }
            }
          ]
        },
        "taxonomicCoverage": {
          "type": "object",
          "properties": {
            "generalTaxonomicCoverage": {
              "type": "array",
