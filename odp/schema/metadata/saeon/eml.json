          "value": {
            "type": "string",
            "minLength": 1
          },
          "lang": {
            "type": "string"
          }
        },
        "required": [
          "value"
        ]
      },
      "translations": [
        {
          "t9nScheme": "saeon/datacite4",
          "t9nTarget": "/titles",
          "t9nArray": {
            "t9nObject": {
              "title": {
                "t9nSource": "0/value"
              },
              "lang": {
                "t9nSource": "0/lang"
              }
            }
          }
        }
      ]
    },
    "pubDate": {
      "type": "string",
