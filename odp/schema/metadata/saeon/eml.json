        "schemaVersion": "http://datacite.org/schema/kernel-4"
      }
    }
  ],
  "properties": {
    "doi": {
      "type": "string",
      "pattern": "^10\\.\\d{4,}(\\.\\d+)*/[-._;()/:a-zA-Z0-9]+$",
