                      "t9nArray": {
                        "t9nObject": {
                          "subject": {},
                          "subjectScheme": {
                            "t9nConst": "EML Spatial Reference: altitudeDistanceUnits"
                          }
                        }
                      }
                    }
                  ]
                }
              }
            },
            "depthSystemDefinition": {
              "type": "object",
              "properties": {
                "depthDatumName": {
                  "type": "string",
                  "translations": [
                    {
                      "t9nScheme": "saeon/datacite4",
                      "t9nTarget": "/subjects",
                      "t9nArray": {
                        "t9nObject": {
                          "subject": {},
                          "subjectScheme": {
                            "t9nConst": "EML Spatial Reference: depthDatumName"
                          }
                        }
                      }
                    }
                  ]
                },
                "depthDistanceUnits": {
                  "type": "string",
                  "translations": [
                    {
                      "t9nScheme": "saeon/datacite4",
                      "t9nTarget": "/subjects",
                      "t9nArray": {
                        "t9nObject": {
                          "subject": {},
                          "subjectScheme": {
                            "t9nConst": "EML Spatial Reference: depthDistanceUnits"
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      },
      "additionalProperties": false
