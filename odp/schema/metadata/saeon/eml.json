                "classificationSystemModifications": {
                  "type": "string"
                },
                "identificationReference": {
                  "type": "string"
                },
                "identifierName": {
                  "type": "string"
                },
                "taxonomicCompleteness": {
                  "type": "string"
                },
                "taxonomicProcedures": {
                  "type": "string"
                },
                "vouchers": {
                  "type": "object",
                  "properties": {
                    "repository": {
                      "type": "object",
                      "properties": {
                        "originator": {
                          "type": "string"
                        }
                      }
                    },
                    "specimen": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "required": [
            "generalTaxonomicCoverage",
            "taxonomicClassification"
          ]
        }
      },
      "additionalProperties": false
