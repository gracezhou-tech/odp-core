    "titles": [
        {
            "lang": "en",
            "value": "Long-term Monitoring of Coastal Biodiversity in False Bay"
        }
    ],
    "methods": {
        "sampling": [
            {
                "citation": "Filander Z, et al. (2024). Quality control and validation procedures for benthic bycatch observer data. SAEON Technical Report.",
                "studyExtent": "Sampling occurred annually between 2009 and 2023 during fishing seasons. The geographic extent covered waters surrounding the Prince Edward and Marion Islands. The study focused on benthic invertebrate bycatch associated with longline fisheries.",
                "samplingDescription": "Observers divided each longline into segments of either 1,200 meters or 1,000 hooks in accordance with Conservation Measure 22-07. Prior to hauling, 50% of the segments were randomly selected for sampling. All benthic bycatch within selected segments was identified, counted and weighed.",
                "spatialSamplingUnits": [
                    "Prince Edward Islands Exclusive Economic Zone",
                    "Longline fishing grounds surrounding Marion Island"
                ]
            }
        ],
        "methodStep": "Data were collected using onboard fisheries observers who monitored longline fishing operations targeting Patagonian toothfish around the Prince Edward and Marion Islands between 2009 and 2023. Observers recorded benthic bycatch by identifying, counting and weighing taxa from selected longline segments. Data were captured using standardized field sheets and later digitised into a central database.",
        "qualityControl": "All records were validated through double data entry checks, taxonomic verification against WoRMS, and automated range checks for spatial coordinates and species occurrence. Outliers were flagged and reviewed by a senior marine ecologist prior to publication."
    },
    "pubDate": "2026-02-27",
    "purpose": "To assess the impact of rising sea temperatures on coastal biodiversity over a 10-year period.",
    "abstract": "This dataset contains long-term monitoring data regarding macroalgae and invertebrate populations collected along the rocky shores of False Bay, South Africa.",
